// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Scenario{
  id               Int @id @default(autoincrement())
  titre            String
  description      String
  anneePublication DateTime @default(now())
  type             TypePublication
  source           String

  auteurId         Int
  auteur           Auteur          @relation(fields: [auteurId], references: [id])
  genreId          Int
  genre            Genre           @relation(fields: [genreId], references: [id])
}

model Genre{
  id               Int @id @default(autoincrement())
  nom              String
  description      String

  scenarios        Scenario[]
}

model SystemeJeu{
  id               Int @id @default(autoincrement())
  nom              String
  description      String
  source           String

  auteurId         Int
  auteur           Auteur     @relation(fields: [auteurId], references: [id])
}

model Auteur{
  id               Int @id @default(autoincrement())
  nom              String
  prenom           String
  
  scenarios        Scenario[]
  systemesJeu      SystemeJeu[]
}

model User{
  id               Int @id @default(autoincrement())
  googleId         String @unique
  userName         String
  email            String
}

model Admin{
  id               Int @id @default(autoincrement())
  googleId         String @unique
  userName         String
  email            String
}

enum TypePublication{
  LIVRE
  MAGAZINE
}
